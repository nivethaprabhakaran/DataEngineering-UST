6 . Write a function minmax(values:Array[Int]) which returns a pair of minimum and maximum values of an array 

scala> def minmax(values: Array[Int]): (Int, Int) = (values.min, values.max)
minmax: (values: Array[Int])(Int, Int)

scala> val nums = Array(5, 2, 9, 1, 7)
nums: Array[Int] = Array(5, 2, 9, 1, 7)

scala> val mm = minmax(nums)
mm: (Int, Int) = (1,9)

scala> println(mm)
(1,9)

