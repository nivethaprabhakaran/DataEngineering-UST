2.Prime Numbers within a range

scala> def cprime(n:Int):Boolean={ if (n<=1) false else if (n==2) true else !(2 until n).exists(i => n % i == 0)}
def cprime(n: Int): Boolean

scala> for(i<-1 to 10 if cprime(i))
     | println(i)
2
3
5
7
